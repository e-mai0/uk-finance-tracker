# Copy this file to .env and fill in your Alpaca PAPER keys:
#   https://app.alpaca.markets/paper/dashboard/overview  ->  "Generate New Keys"

ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# true  = paper trading (simulated money). KEEP THIS TRUE while developing.
# false = real money, and is additionally gated behind ALLOW_LIVE=yes in run.py.
ALPACA_PAPER=true

# Comma-separated symbols to trade.
SYMBOLS=AAPL,MSFT,SPY

# Example SMA strategy periods (placeholder strategy — replace with your own).
FAST_PERIOD=20
SLOW_PERIOD=50

# Seconds between evaluation passes when running the loop.
POLL_SECONDS=60

# --- Risk limits (fractions of equity) ---
MAX_POSITION_PCT=0.10          # max exposure to a single symbol
MAX_DAILY_LOSS_PCT=0.03        # stop trading after this daily loss
KILL_SWITCH_DRAWDOWN_PCT=0.15  # halt everything past this drawdown from the peak
