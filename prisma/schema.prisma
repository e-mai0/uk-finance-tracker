// UK Finance Summer Internship Tracker — data model
// Provider: PostgreSQL (Supabase). Uses pooled DATABASE_URL for the app
// and DIRECT_URL for migrations (see README / .env.example).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RoleFamily {
  IB // Investment banking
  MARKETS // Sales & trading / markets
  ASSET_MGMT // Asset / investment management
  PRIVATE_EQUITY // PE / private credit
  HEDGE_FUND // Buy-side / hedge fund
  QUANT // Quant / systematic trading
  CORP_BANKING // Corporate banking / capital markets
  RESEARCH // Equity / macro research
}

enum OpportunityStatus {
  OPEN
  OPENING_SOON
  CLOSED
  UNKNOWN
}

// Programme season — first-class classified data (replaces the UK-summer-only
// assumption). Spelling MUST match the ProgrammeType string-literal union in
// src/lib/constants.ts (the app-level source of truth). WINTER folds into
// OFF_CYCLE per ADR-003.
enum ProgrammeType {
  SPRING_WEEK
  SUMMER_INTERNSHIP
  OFF_CYCLE
  INDUSTRIAL_PLACEMENT
}

// Region — first-class classified data. Spelling MUST match the Region
// string-literal union in src/lib/constants.ts.
enum Region {
  UK
  US
  HK
  OTHER
}

enum WorkAuth {
  UK_CITIZEN
  UK_SETTLED // ILR / settled / pre-settled
  UK_VISA_REQUIRED // needs sponsorship
  OTHER
}

enum SourceType {
  CAREERS_PAGE
  GREENHOUSE
  LEVER
  ASHBY
  WORKDAY
  ORACLE_CLOUD
  EIGHTFOLD
  AVATURE
  RADANCY
  TALNET
  MANUAL
}

// Applicant tracking system the external application form is hosted on.
enum ATSKind {
  GREENHOUSE
  LEVER
  ASHBY
  WORKDAY
  OTHER
}

// Lifecycle of a real application the user is making to an external role.
enum ApplicationStatus {
  DRAFT
  AUTOFILLED
  SUBMITTED
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

// Where an Application record originated.
enum ApplicationSource {
  EXTENSION
  MANUAL
}

// Kind of AI-generated artefact (kept for history / reuse).
enum DraftKind {
  COVER_LETTER
  ANSWER
  CV_TAILOR
}

// ---------------------------------------------------------------------------
// Users & profiles
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  createdAt    DateTime  @default(now())
  onboardedAt  DateTime?

  profile       Profile?
  preferences   Preferences?
  applyProfile  ApplyProfile?
  builtCv       BuiltCv?
  saved         SavedOpportunity[]
  matches       MatchScore[]
  apiTokens     ApiToken[]
  answerBank    AnswerBankItem[]
  applications  Application[]
  drafts        GeneratedDraft[]
  memoryFiles     MemoryFile[]
  chatSessions    ChatSession[]
  attentionItems  AttentionItem[]
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  university     String
  degreeSubject  String
  degreeType     String
  graduationYear Int
  currentYear    Int
  workAuth       WorkAuth?
  gradeInfo      Json? // optional A-level / GCSE / GPA style fields
  skills         String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Preferences {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRoleFamilies RoleFamily[] @default([])
  preferredLocations String[]     @default([])
  openToAnywhereUk   Boolean      @default(false)
  targetEmployers    String[]     @default([])
  updatedAt          DateTime     @updatedAt
}

// ---------------------------------------------------------------------------
// Opportunities & employers
// ---------------------------------------------------------------------------

model Employer {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  sector        String?
  hq            String?
  website       String?
  logoHint      String? // short label for an avatar/monogram in the UI
  opportunities Opportunity[]
  research      EmployerResearch?
}

model Opportunity {
  id                 String            @id @default(cuid())
  employerId         String
  employer           Employer          @relation(fields: [employerId], references: [id], onDelete: Cascade)
  title              String
  programmeType      String // legacy normalized label, e.g. "Summer Internship" (retained; kept in sync from the enum)
  // Season + region taxonomy (ADR-003). Downstream units read/write these two
  // NEW columns: `programmeTypeEnum` (classified season) and `region`
  // (classified region). Defaults backfill existing rows correctly
  // (every legacy row IS a UK summer internship). The legacy `programmeType`
  // String, `country`, `isUkBased`, `isSummerInternship` are retained and
  // derived from these for now (retirement is a later cycle).
  programmeTypeEnum  ProgrammeType     @default(SUMMER_INTERNSHIP)
  region             Region            @default(UK)
  roleFamily         RoleFamily
  divisionDesk       String?
  location           String
  country            String            @default("UK")
  isUkBased          Boolean           @default(true)
  isSummerInternship Boolean           @default(true)
  applicationUrl     String?
  sourceUrl          String?
  sourceType         SourceType        @default(MANUAL)
  status             OpportunityStatus @default(UNKNOWN)
  opensAt            DateTime?
  deadlineAt         DateTime?
  firstSeenAt        DateTime          @default(now())
  lastSeenAt         DateTime          @default(now())
  descriptionSummary String // original normalized summary (no copied content)
  eligibilityNotes   String?
  sponsorshipInfo    String?
  confidence         Float             @default(1.0)
  deadlineEstimated  Boolean           @default(false)
  isRolling          Boolean           @default(false)
  consecutiveMisses  Int               @default(0)
  closedAt           DateTime?
  closeReason        String?

  tags         OpportunityTag[]
  sources      OpportunitySource[]
  saved        SavedOpportunity[]
  matches      MatchScore[]
  applications Application[]

  @@unique([employerId, title, location])
  @@index([roleFamily])
  @@index([status])
  @@index([location])
  @@index([deadlineAt])
  @@index([lastSeenAt])
}

model OpportunityTag {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  label         String

  @@index([opportunityId])
  @@index([label])
}

model OpportunitySource {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  sourceType    SourceType
  url           String
  label         String?

  @@index([opportunityId])
}

// ---------------------------------------------------------------------------
// User <-> opportunity relations
// ---------------------------------------------------------------------------

model SavedOpportunity {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  notes         String?
  createdAt     DateTime    @default(now())

  @@unique([userId, opportunityId])
  @@index([userId])
}

model MatchScore {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  score         Int
  reasons       Json // string[]
  computedAt    DateTime    @default(now())

  @@unique([userId, opportunityId])
  @@index([userId])
  @@index([userId, score])
}

// ---------------------------------------------------------------------------
// Ingestion metadata
// ---------------------------------------------------------------------------

model IngestionRun {
  id         String    @id @default(cuid())
  source     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  created    Int       @default(0)
  updated    Int       @default(0)
  notes      String?
}

// A live ingestion source the sync job polls — one row per public ATS job
// board (Greenhouse / Lever / Ashby). Rows are seeded for known employers and
// created by users through Firm Scout ("paste a careers URL"), which is how
// niche/boutique firms enter the dataset without a code change. `identifier`
// is the ATS-specific board key (Greenhouse board token, Lever site name,
// Ashby job-board name). Unsupported-but-recognised boards (e.g. Workday) are
// stored disabled as a review queue.
model IngestionSource {
  id                  String     @id @default(cuid())
  kind                SourceType
  identifier          String
  employerName        String
  sector              String?
  url                 String? // the human URL the source was derived from
  enabled             Boolean    @default(true)
  // Watch-only sources (custom ATS sites with no machine-readable feed) are
  // monitored for change — sitemap URL diffs or a page content hash — and
  // flagged for review on /radar rather than auto-published.
  watchOnly           Boolean    @default(false)
  watchState          Json? // { kind: "sitemap", urls } | { kind: "page", hash }
  config                Json?
  lastSuccessfulFetchAt  DateTime?
  lastChangedAt       DateTime?
  suggestedById       String? // userId of the scout who added it (informational)
  lastRunAt           DateTime?
  lastStatus          String? // e.g. "ok: 3 created, 1 updated"
  lastError           String?
  consecutiveFailures Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([kind, identifier])
  @@index([enabled])
}

// ---------------------------------------------------------------------------
// Apply copilot — application profile, answer bank, tokens, tracking
// ---------------------------------------------------------------------------

// Reusable data the apply copilot fills into / drafts against external
// application forms. Separate from Profile (which drives match scoring) so the
// two concerns evolve independently.
model ApplyProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone       String?
  addressCity String?
  country     String? @default("United Kingdom")
  linkedinUrl String?
  githubUrl   String?
  websiteUrl  String?
  pronouns    String?

  noticePeriod         String?
  earliestStart        String?
  // Short reusable free-text statements the copilot can drop into common
  // application questions verbatim or as grounding for generation.
  workAuthStatement    String?
  sponsorshipStatement String?

  // Optional self-identification, only persisted if the user opts in.
  selfIdGender    String?
  selfIdEthnicity String?

  // CV (migrated off Profile): now a real upload + parsed text.
  cvStoragePath String? // path within the private `cvs` bucket
  cvFileName    String?
  cvFileSize    Int?
  cvText        String? // extracted plain text used to ground generation
  cvUpdatedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Reusable Q&A that grows as the user applies. `questionNormalized` is the
// lower-cased / stripped form used for fuzzy matching against new questions.
model AnswerBankItem {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionNormalized String
  questionText       String
  answer             String
  tags               String[] @default([])
  employer           String?
  usageCount         Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([userId, questionNormalized])
}

// A real application the user is making to an external role. `opportunityId`
// is optional because users apply to roles that aren't in our dataset.
model Application {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  externalUrl  String
  employerName String?
  roleTitle    String?
  ats          ATSKind           @default(OTHER)
  status       ApplicationStatus @default(DRAFT)
  source       ApplicationSource @default(EXTENSION)
  submittedAt  DateTime?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  drafts GeneratedDraft[]

  @@unique([userId, externalUrl])
  @@index([userId])
  @@index([userId, status])
}

// History of AI-generated artefacts (cover letters, answers, CV tailoring).
model GeneratedDraft {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  opportunityId String?
  kind          DraftKind
  context       Json? // prompt context (question, employer, role, char limit)
  content       String
  model         String?
  provenance    String?      @db.Text // JSON Provenance
  createdAt     DateTime     @default(now())

  @@index([userId])
}

// Personal API tokens used by the browser extension. Only the SHA-256 hash is
// stored; the plaintext is shown once at creation and handed to the extension.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  name       String    @default("Browser extension")
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Cyclops — memory, chat, gardener, usage (Phase 1)
// ---------------------------------------------------------------------------

enum AttentionKind {
  PROPOSAL
  FLAG
  QUESTION
  BRIEF
}

enum AttentionStatus {
  OPEN
  SNOOZED
  RESOLVED
}

enum MemoryAuthor {
  USER
  CYCLOPS
}

model MemoryFile {
  id        String           @id @default(cuid())
  userId    String
  path      String
  content   String           @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions MemoryRevision[]

  @@unique([userId, path])
  @@index([userId])
}

model MemoryRevision {
  id           String       @id @default(cuid())
  memoryFileId String
  before       String       @db.Text
  after        String       @db.Text
  author       MemoryAuthor
  reason       String?
  createdAt    DateTime     @default(now())
  file         MemoryFile   @relation(fields: [memoryFileId], references: [id], onDelete: Cascade)

  @@index([memoryFileId, createdAt])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  kind      String        @default("cyclops") // "cyclops" | "cv-builder"
  title     String        @default("New conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  clientId  String?
  role      String // "user" | "assistant"
  parts     String      @db.Text // JSON-serialised UIMessage parts
  aborted   Boolean     @default(false)
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, clientId])
  @@index([sessionId, createdAt])
}

/// One canonical "pending decision" store (spec §4.3). Every nav badge is a
/// filtered count over OPEN rows; resolving anywhere decrements all views.
model AttentionItem {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         AttentionKind
  status       AttentionStatus @default(OPEN)
  /// Stable dedupe key so cron re-runs upsert instead of duplicating,
  /// e.g. "brief:2026-06-11", "gq:<id>", "draft:<id>".
  key          String
  /// "chat-session" | "draft" | "opportunity" | "application" | "gardener-question"
  targetType   String
  targetId     String
  title        String
  meta         Json?
  snoozedUntil DateTime?
  createdAt    DateTime        @default(now())
  resolvedAt   DateTime?

  @@unique([userId, key])
  @@index([userId, status])
}

model GardenerQuestion {
  id        String   @id @default(cuid())
  userId    String
  question  String
  status    String   @default("pending") // pending | asked | resolved
  createdAt DateTime @default(now())

  @@index([userId, status])
}

model GardenerRun {
  id     String   @id @default(cuid())
  userId String
  ranAt  DateTime @default(now())

  @@index([userId, ranAt])
}

model DailyUsage {
  id     String @id @default(cuid())
  userId String
  day    String // YYYY-MM-DD (UTC)
  tokens Int    @default(0)

  @@unique([userId, day])
}

// ---------------------------------------------------------------------------
// Cyclops Phase 1 — vector embeddings (managed via prisma/sql/2026-06-09-pgvector.sql)
// ---------------------------------------------------------------------------

// Shadow model so Prisma does not drift-drop the raw SQL table.
// Column/index shapes must match the SQL file exactly.
model ContentEmbedding {
  id        String   @id
  userId    String   @map("user_id")
  kind      String
  sourceId  String   @map("source_id")
  content   String
  embedding Unsupported("vector(1024)")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([kind, sourceId])
  @@index([userId, kind])
  @@map("content_embeddings")
}

// ---------------------------------------------------------------------------
// Cyclops Phase 2 — writing engine (draft editing, employer research)
// ---------------------------------------------------------------------------

model DraftEdit {
  id        String   @id @default(cuid())
  userId    String
  draftId   String // GeneratedDraft id
  original  String   @db.Text
  edited    String   @db.Text
  distilled Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, distilled])
}

model EmployerResearch {
  id          String   @id @default(cuid())
  employerId  String   @unique
  content     String   @db.Text // markdown: divisions, culture signals, recent news, common questions
  model       String
  refreshedAt DateTime
  employer    Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// CV Builder — structured CV built via guided form + chatbot
// ---------------------------------------------------------------------------

model BuiltCv {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data          Json     // CvData — source of truth for preview & exports
  formInput     Json?    // raw 3-step form answers (kept for re-edit)
  chatSessionId String?  // dedicated CV-builder chat thread
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
