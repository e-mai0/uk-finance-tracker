{
  "manifest_version": 3,
  "name": "Trackr Autofill",
  "version": "0.1.0",
  "description": "Fills finance internship application forms from your Trackr profile and drafts answers on the page. You always review and submit.",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Trackr Autofill"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*",
    "https://trackr-brown.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["http://localhost:3000/*", "https://trackr-brown.vercel.app/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*", "https://trackr-brown.vercel.app/*"],
      "js": ["src/content/connect.ts"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost:3000/*", "https://trackr-brown.vercel.app/*"]
  }
}
