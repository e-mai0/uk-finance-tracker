{
  "manifest_version": 3,
  "name": "Cyclops Autofill",
  "version": "0.1.0",
  "description": "Fills finance internship application forms from your Cyclops profile and drafts answers on the page. You always review and submit.",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Cyclops Autofill"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.ashbyhq.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://cyclops-brown.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.ashbyhq.com/*",
        "https://*.myworkdayjobs.com/*"
      ],
      "js": ["src/content/index.ts"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*", "https://cyclops-brown.vercel.app/*"],
      "js": ["src/content/connect.ts"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost:3000/*", "https://cyclops-brown.vercel.app/*"]
  }
}
