{
  "name": "trackr-autofill-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Trackr Autofill — fills finance internship application forms from your Trackr profile and drafts answers on the page. You always review and submit.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/widen-war.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.34",
    "@types/chrome": "^0.0.287",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
