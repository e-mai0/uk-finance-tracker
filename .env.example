# ---------------------------------------------------------------------------
# Database — Supabase Postgres
# ---------------------------------------------------------------------------
# Get these from Supabase: Project → Settings → Database → Connection string.
#
# DATABASE_URL  = the POOLED connection (Transaction mode, port 6543, has
#                 `?pgbouncer=true`). Used by the app at runtime (serverless-safe).
# DIRECT_URL    = the DIRECT connection (Session mode, port 5432). Used by
#                 Prisma Migrate only.
#
# Example (replace [PROJECT-REF], [PASSWORD], [REGION]):
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# ---------------------------------------------------------------------------
# Generate one with:  npx auth secret   (or)   openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Base URL of the app (used by Auth.js for callbacks). Local default below.
AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Apply copilot (optional — the app runs without these, the copilot degrades
# gracefully and tells the user when a piece isn't configured)
# ---------------------------------------------------------------------------
# Anthropic API key for AI answer / cover-letter generation (server-only).
ANTHROPIC_API_KEY="sk-ant-..."

# Supabase project URL + SERVICE-ROLE key for private CV file storage.
# Settings → API. The service-role key bypasses RLS — keep it server-only.
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

# ---------------------------------------------------------------------------
# Cyclops — memory, chat, semantic search (Phase 1)
# ---------------------------------------------------------------------------
# Voyage AI embeddings key (voyage-3.5-lite, 1024 dims).
# Get from: https://www.voyageai.com/
VOYAGE_API_KEY=

# Per-user daily token budget for Cyclops AI operations.
CYCLOPS_DAILY_TOKEN_BUDGET=2000000

# ---------------------------------------------------------------------------
# Cron auth (Cyclops crons + Radar /api/ingest/sync)
# ---------------------------------------------------------------------------
# Shared secret protecting cron routes. Vercel Cron sends it automatically
# as `Authorization: Bearer $CRON_SECRET`; use the same header for manual runs.
CRON_SECRET="replace-with-a-long-random-string"

# ---------------------------------------------------------------------------
# Early access gate (optional)
# ---------------------------------------------------------------------------
# When set, /signup requires this invite code before an account is created
# (trimmed, case-insensitive). Share it with your cohort; rotate it by changing
# this value; open signups to everyone by leaving it UNSET. No code change
# needed to toggle — the signup page shows/hides the invite field from this.
EARLY_ACCESS_CODE="cyclops-early-2026"

# ---------------------------------------------------------------------------
# Upstash Redis (optional) — resumable Ask Cyclops streams
# ---------------------------------------------------------------------------
# Provision via the Vercel Marketplace (Upstash Redis) and set the connection
# URL here and in Vercel. When set, a streaming chat answer is buffered so it
# survives navigation: opening another session and returning reattaches to the
# live stream instead of the answer collapsing mid-stream. When UNSET, chat
# still works exactly as before — answers persist and reload — just without
# live reattachment. No code change needed to toggle.
REDIS_URL=
